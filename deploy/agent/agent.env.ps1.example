# NetProspect — config do agente PULL (Windows). Copia para agent.env.ps1 e preenche.
# agent.env.ps1 é gitignored (contém o token).

$FLEET_HOST       = "gpedro-laptop"                       # tem de bater com o FLEET_HOST do worker do laptop
$SERVER_URL       = "http://100.114.17.74:3001"           # dashboard np-server (tailnet)
$FLEET_PULL_TOKEN = ""                                    # igual ao FLEET_PULL_TOKEN do np-server (vazio = tailnet-gated)
$REPO             = "C:\Users\gpedro\netprospect-v1"      # pasta do repo no laptop (AJUSTA)
$COMPOSE_FILE     = "deploy\laptop\docker-compose.yml"    # relativo a $REPO
$COMPOSE_PROJECT  = "laptop"                              # nome do projeto (prefixo em `docker ps`) — OBRIGATÓRIO
$ENV_TARGET       = "$REPO\deploy\laptop\.env"            # onde escrever o .env puxado
