# Config do auto-deploy PULL para o host que serve a plataforma de docs (np-server).
# Copiar para agent.env no host e ajustar. LAN_IP/TAILNET_IP vêm do store da frota (.env).
FLEET_HOST=np-server
SERVER_URL=http://100.114.17.74:3001
COMPOSE_FILE=deploy/docs/docker-compose.yml
COMPOSE_PROJECT=npdocs
COMPOSE_SERVICES=docs-web
COMPOSE_NO_DEPS=1
COMPOSE_BUILD=0
# NB: o site (docs-site/dist) é reconstruído por deploy/docs/build.sh (systemd timer), não pelo
# recreate do container — ver deploy/docs/README.md.
