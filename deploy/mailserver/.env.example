# Config da VM de envio (docker-mailserver). Copiar p/ .env e preencher — UM .env por VM/domínio.
# Ver ./README.md.

# Hostname do DMS = TEM de ser igual ao PTR do IP desta VM e ao MX/A do domínio (ex. mail.<domínio>).
MAIL_HOSTNAME=mail.secondary-domain-1.tld

# Endereço de postmaster (recebe relatórios). Numa mailbox do próprio domínio.
POSTMASTER_ADDRESS=postmaster@secondary-domain-1.tld

# TLS: 'letsencrypt' (precisa de :80 livre p/ o desafio ou DNS-01) · 'manual' (montar cert) · 'self-signed' (só dev).
SSL_TYPE=letsencrypt

# Tag da imagem (fixar em produção; 'latest' p/ testar).
DMS_TAG=latest
LOG_LEVEL=info
