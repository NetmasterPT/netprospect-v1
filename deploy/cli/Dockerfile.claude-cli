# Claude Code CLI num container (provider claude-cli). Auth por -e: ANTHROPIC_API_KEY (API) ou
# CLAUDE_CODE_OAUTH_TOKEN (subscrição Claude Pro/Max). Uso: docker run --rm -i -e CLAUDE_CODE_OAUTH_TOKEN \
#   netprospect/claude-cli claude -p   (prompt via stdin)
FROM node:22-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates git \
  && rm -rf /var/lib/apt/lists/* \
  && npm install -g @anthropic-ai/claude-code \
  && npm cache clean --force
WORKDIR /work
