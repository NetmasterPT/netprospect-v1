# Copia para docker/.env e preenche.
# Gera os segredos com:  openssl rand -hex 32

# --- Postgres ---
POSTGRES_USER=netprospect
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=netprospect

# --- Directus ---
DIRECTUS_KEY=generate-with-openssl-rand-hex-32
DIRECTUS_SECRET=generate-with-openssl-rand-hex-32
# NB: usa um TLD válido — o Directus rejeita .local como email inválido.
DIRECTUS_ADMIN_EMAIL=admin@netprospect.pt
DIRECTUS_ADMIN_PASSWORD=change-me-strong
DIRECTUS_ADMIN_TOKEN=generate-with-openssl-rand-hex-32
DIRECTUS_PORT=8056
DIRECTUS_PUBLIC_URL=http://localhost:8056

# --- Lido pelos scripts Node (bootstrap-directus.js, enrich-sites.js) ---
DIRECTUS_URL=http://localhost:8056
# DIRECTUS_TOKEN pode ficar igual ao DIRECTUS_ADMIN_TOKEN acima.
DIRECTUS_TOKEN=generate-with-openssl-rand-hex-32

# --- MaxMind GeoLite2 (opcional; sem isto usa-se o fallback Team Cymru) ---
# License key gratuita: https://www.maxmind.com/en/geolite2/signup
MAXMIND_LICENSE_KEY=

# --- Pipeline de jobs (NATS JetStream + workers) — Fase 2 ---
# Réplicas do worker (docker compose up -d --scale worker=N ou este default).
WORKER_REPLICAS=2
# Concorrência interna por worker.
ENRICH_CONCURRENCY=10
CONTACTS_CONCURRENCY=5
# Liga o consumo das auditorias pesadas (Fase 2b). Em 2a fica false.
AUDIT_ENABLED=false
# Ollama (classificação de atividade, perfil `audit`). gemma3:4b p/ qualificados/
# on-demand; gemma3:1b para a cauda longa.
OLLAMA_MODEL=gemma3:4b
# WPScan (só on-demand, 25/dia grátis): https://wpscan.com/api
WPSCAN_API_TOKEN=

# --- Tailscale (só no perfil `tailscale`; expor Directus via npmPlus/netmaster.pt) ---
# Auth key da tailnet (de preferência com tag): https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=
TS_HOSTNAME=netprospect-directus

# --- MinIO (snapshots de páginas + reports integrais das auditorias) ---
# EM PRODUÇÃO o MinIO vive numa VM dedicada no DE1 (`de-minio`, disco barato) — NÃO no host da app:
# é escreve-1×/lê-raro e latency-tolerante, logo desperdiçava NVMe. Ver docs/runbook-minio-de1.md.
#   produção → MINIO_URL=http://<de-minio-tailnet-ip>:9000   (o mesmo valor em TODA a frota)
#   local/dev → MINIO_URL=http://minio:9000                  (o serviço `minio` do compose)
MINIO_URL=http://minio:9000
MINIO_ROOT_USER=netprospect
MINIO_ROOT_PASSWORD=change-me-minio
MINIO_BUCKET=snapshots
MINIO_REPORTS_BUCKET=reports
# Worker roles (Fase B): vazio=todos; ex.: base | browser | security
WORKER_ROLES=

# --- Egresso por exit node Tailscale (Fase C; perfil `egress`) ---
# Nome/IP do exit node na tailnet (ex.: hetzner-fsn1). Workers: EGRESS_PROXY=http://tailscale-egress:1055
TS_EXIT_NODE=
EGRESS_PROXY=

# IP tailnet deste host — expõe NATS/MinIO/Redis à frota remota (mantendo 127.0.0.1).
# NUNCA público (NATS/Redis sem auth). Descobre com: tailscale ip -4
TAILNET_IP=100.64.0.1
