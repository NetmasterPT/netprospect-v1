# Gemini CLI num container (provider gemini-cli). Auth por -e: GEMINI_API_KEY (API) ou GOOGLE_OAUTH_TOKEN
# (conta Google / Code Assist free ~1000/dia). Uso: docker run --rm -i -e GEMINI_API_KEY \
#   netprospect/gemini-cli gemini -p "<prompt>"   (prompt via arg)
FROM node:22-slim
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates git \
  && rm -rf /var/lib/apt/lists/* \
  && npm install -g @google/gemini-cli \
  && npm cache clean --force
WORKDIR /work
