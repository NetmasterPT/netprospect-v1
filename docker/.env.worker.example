# docker/.env.worker.example — copiar p/ docker/.env.worker em cada VM da frota.
# (docker/.env.worker é gitignored — ver .gitignore.)
#
# Preencher com os endereços TAILNET do host central + o static token do Directus.
# Descobre o IP tailnet do host central com `tailscale ip -4` NESSE host.

# --- Stack central (via Tailnet) ---
NATS_URL=nats://100.x.y.z:4222          # IP tailscale do host central (NATS_BIND lá = esse IP)
DIRECTUS_URL=http://100.x.y.z:8056      # ou o URL público: https://prospect.netmaster.pt
DIRECTUS_TOKEN=cola-o-mesmo-static-token-do-docker/.env-central

# --- Papel deste VM ---
WORKER_ROLES=verify                     # verify | base | verify,base | (vazio = todos)
VERIFY_CONCURRENCY=4                    # subir só se houver muitas chaves/IPs neste VM
VERIFY_TIMEOUT_MS=8000
VERIFY_MAX_CANDIDATES=4

# --- Reacher opcional (verificação SMTP self-hosted) — vazio = só APIs free ---
REACHER_URL=
REACHER_FROM_EMAIL=

# --- MinIO: só se este VM correr WORKER_ROLES=base (crawling lê snapshots) ---
MINIO_URL=                              # http://100.x.y.z:9000 (tailnet do host central)
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# --- Escrita DIRETA no Postgres (A2) — só p/ roles `base`. Aponta ao PgBouncer do host de DB (CT). ---
DIRECT_PG_WRITE=true                    # false/vazio p/ workers SÓ-verify (não escrevem sites)
PG_WRITE_HOST=100.100.1.10             # IP tailnet do np-db (CT)
PG_WRITE_PORT=6432                      # PgBouncer
PG_WRITE_USER=<appuser>
PG_WRITE_PASSWORD=<POSTGRES_PASSWORD>
PG_WRITE_DB=<POSTGRES_DB>

# --- Telemetria (dashboard /workers) — Redis do host central via tailnet. Vazio = sem telemetria. ---
REDIS_URL=                              # redis://100.x.y.z:6379 (expor o redis no tailnet p/ isto)

# --- WHOIS router (Part B) — só se este VM correr whois/verify ---
WHOISXML_API_KEYS=                      # csv de keys WhoisXML (best-effort .pt); vazio = tier inerte
RDAP_RATE_PER_SEC=5                     # rate-limit RDAP por-registry (por IP deste VM)

WORKER_REPLICAS=1                       # verify: 1 por VM (o IP é o recurso). base: pode ser 2-4 se houver cores.
