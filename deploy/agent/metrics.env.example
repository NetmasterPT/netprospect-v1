# NetProspect — config do reporter de telemetria STANDALONE (metrics-report.sh).
# Copia para /etc/netprospect-metrics.env e preenche. Para máquinas de infra sem repo/docker (ex.: np-db).

# Nome do host tal como deve aparecer na página VMs/Servidores.
FLEET_HOST=np-db

# URL do dashboard (np-server) na tailnet.
SERVER_URL=http://100.114.17.74:3001

# Token de métricas (igual ao FLEET_PULL_TOKEN do np-server). Vazio = o server aceita só por tailnet.
FLEET_PULL_TOKEN=

# --- Latências (opcional): medidas a partir deste host ---
# Directus (control-plane). Vazio = não mede.
DIRECTUS_PING_URL=http://100.114.17.74:8056/server/ping
# MinIO/NAS. Vazio = não mede.
# MINIO_HEALTH_URL=http://100.124.43.117:9000/minio/health/live
# Postgres local (num CT de DB mede o loopback). Vazio = não mede.
PG_HOST=127.0.0.1
PG_PORT=5432
