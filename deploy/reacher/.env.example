# deploy/reacher/.env — preencher no deploy (Fase 1) e guardar como .env (gitignored).
# Copiar: cp .env.example .env  e editar.

# IP tailnet do HOST onde corre o Reacher (de-minio no piloto). O Reacher escuta AQUI; o worker verify
# (hel1-docker) faz POST a http://${TAILNET_IP}:8080. NÃO pôr o IP público.
TAILNET_IP=100.124.43.117

# Nome HELO/PTR — tem de bater com o PTR do IP público de egress (49.12.120.250 → p1.<domínio-descartável>).
# É o fallback global do container; o valor por-request vem do campo `helo` em config/verify-proxies.json.
REACHER_HELLO=p1.CHANGE-ME.example
REACHER_FROM=verify@CHANGE-ME.example

# (Opcional, hardening) segredo do header x-reacher-secret. Se definido, pôr o MESMO no env do worker
# (REACHER_HEADER_SECRET) — mas o lib/reacher.js atual não o envia, por isso deixar vazio no piloto.
# REACHER_SECRET=

# LEMBRETE (não usado pela compose): a password do user `proxyuser` no HOST tem de ser igual ao campo
# `pass` em config/verify-proxies.json. Gerar forte:  openssl rand -hex 16
