# np-server — copiar os valores de docker/.env do HEL1 (as MESMAS chaves/segredos:
# se o DIRECTUS_KEY/SECRET/ADMIN_TOKEN mudarem, os scripts e workers deixam de autenticar).

# --- Interfaces (obrigatório) ---
LAN_IP=10.10.10.81        # IP LAN desta VM — os workers do HEL1 entram por aqui (rápido)
TAILNET_IP=               # tailscale ip -4 — os workers remotos (DE1, free VMs) entram por aqui

# --- Directus ---
DIRECTUS_KEY=
DIRECTUS_SECRET=
DIRECTUS_ADMIN_EMAIL=
DIRECTUS_ADMIN_PASSWORD=
DIRECTUS_ADMIN_TOKEN=
DIRECTUS_PUBLIC_URL=http://10.10.10.81:8056

# --- Postgres (np-db, via tailnet) ---
PG_HOST=100.77.60.44
POSTGRES_DB=netprospect
POSTGRES_USER=netprospect
POSTGRES_PASSWORD=

# --- Serviços noutras VMs (URL completo, não nome de rede) ---
OLLAMA_URL=               # http://<hel1-ollama-tailnet>:11434  (vazio = agentes IA desligados)
OLLAMA_MODEL=gemma3:4b
OLLAMA_TIMEOUT_MS=150000  # Ollama em CPU (sem GPU) → ~100s+/inferência
CLICKHOUSE_URL=           # http://<de-analytics-tailnet>:8123  (vazio = analytics desligado)
CLICKHOUSE_DB=netprospect
CLICKHOUSE_USER=netprospect
CLICKHOUSE_PASSWORD=

CACHE_TTL=60
SMTP_HOST=
