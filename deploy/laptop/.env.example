# gpedro-laptop — copiar os endpoints da frota (tailnet). SEM segredos de DB aqui: o worker
# fala com o Directus por token, não com o Postgres direto (DIRECT_PG_WRITE fica off no portátil).

# --- Endpoints da frota (tailnet) ---
NATS_URL=nats://100.114.17.74:4222        # np-server (control-plane)
DIRECTUS_URL=http://100.114.17.74:8056
DIRECTUS_TOKEN=                            # o ADMIN_TOKEN do docker/.env do HEL1
MINIO_URL=http://100.124.43.117:9000       # de-minio
MINIO_ROOT_USER=netprospect
MINIO_ROOT_PASSWORD=
REDIS_URL=redis://100.114.17.74:6379      # np-server (telemetria)

# --- Perfil ---
# residential = só o GMB (defeito, o valor único do portátil). Para mais carga quando estiver
# livre e o Claude pedir: residential,security,base
WORKER_ROLES=residential
WORKER_REPLICAS=1
GMB_CONC=1

# NÃO escreve direto ao Postgres (é um host residencial, intermitente) → via Directus/writer.
DIRECT_PG_WRITE=false
