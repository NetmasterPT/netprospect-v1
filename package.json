  "type": "module",
  "main": "crtsh-enum.js",
  "scripts": {
    "bootstrap": "node bootstrap-directus.js",
    "tld:pt": "node tld-domains-v2.js pt --restart --crawls=1 --concurrency=6 --delay=200 > out/tld-domains_pt-v2.log 2>&1 &",
    "tld:nl": "node tld-domains-v2.js nl --restart --crawls=1 --concurrency=6 --delay=200 > out/tld-domains_nl-v2.log 2>&1 &",
    "tld:no": "node tld-domains-v2.js no --restart --crawls=1 --concurrency=6 --delay=200 > out/tld-domains_no-v2.log 2>&1 &",
    "tld:se": "node tld-domains-v2.js se --restart --crawls=1 --concurrency=6 --delay=200 > out/tld-domains_se-v2.log 2>&1 &",
    "tld:fi": "node tld-domains-v2.js fi --restart --crawls=1 --concurrency=6 --delay=200 > out/tld-domains_fi-v2.log 2>&1 &",
    "tld": "./run-parallel-tlds.sh",
    "enrich:sites": "node enrich-sites.js",
    "enrich:subdomains": "node enrich-subdomains.js",
    "extract": "node extract-contacts.js",
    "extract:all": "node extract-contacts.js --all",
    "geoip": "node update-geoip.js",
    "geoip:force": "node update-geoip.js --force",
    "build:dash": "cd docker && docker compose build dashboard && docker compose up -d dashboard",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@directus/sdk": "^23.0.0",
    "chrome-launcher": "^1.2.1",
    "imapflow": "^1.4.7",
    "libphonenumber-js": "^1.13.8",
    "lighthouse": "^13.4.0",
    "mailparser": "^3.9.14",
    "maxmind": "^5.0.6",
    "minio": "^8.0.7",
    "nats": "^2.29.3",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "posthog-js": "^1.402.0",
    "puppeteer-core": "^25.3.0",
    "redis": "^6.1.0",
    "simple-wappalyzer": "^1.1.100",
    "socks": "^2.8.9",
    "tldts": "^7.4.7",
    "undici": "^8.7.0",
    "whoiser": "^2.0.0-beta.10"
  }
}
