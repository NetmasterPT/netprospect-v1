# NetProspect — config do agente de auto-deploy por PULL. Copia para agent.env e preenche.
# agent.env é gitignored (pode conter o token). Um por host.

# Nome do host tal como aparece no dashboard (Servers) e no store de .env (<host>.env no np-server).
# TEM de bater com o FLEET_HOST do worker desse host.
FLEET_HOST=np-wk-de1

# URL do dashboard (np-server) na tailnet.
SERVER_URL=http://100.114.17.74:3001

# Token de pull (igual ao FLEET_PULL_TOKEN do np-server). Vazio = o server aceita só por tailnet.
FLEET_PULL_TOKEN=

# Compose file deste host, relativo à raiz do repo. Exemplos:
#   worker VM (de1/oracle): deploy/worker/docker-compose.yml
#   hel1 control-plane:     docker/docker-compose.yml
#   laptop:                 deploy/laptop/docker-compose.yml
COMPOSE_FILE=deploy/worker/docker-compose.yml

# OBRIGATÓRIO — nome do projeto compose (o prefixo dos containers em `docker ps`). Sem isto o
# compose usaria o nome da pasta como projeto e criaria um SEGUNDO conjunto duplicado. Por host:
#   de1 / oracle: npworker      hel1: netprospect      laptop: laptop
COMPOSE_PROJECT=npworker

# Onde escrever o .env puxado (por omissão = <dir do compose>/.env). Descomenta p/ override.
# ENV_TARGET=/root/netprospect-v1/deploy/worker/.env

# Serviços a recriar (vazio = todos os do compose). Ex.: "worker worker-base".
COMPOSE_SERVICES=

# 1 = correr `up --build` (hosts com imagem baked, ex. np-server). 0 = só recreate (código montado).
COMPOSE_BUILD=0

# 1 = NÃO fazer git pull (ex.: hel1, onde se committa e o working tree está sempre à frente).
# Nesse caso o agente só reage a mudanças do .env. Por omissão 0 (faz git pull).
SKIP_GIT=0

# Serviços a recriar (vazio = todos). No hel1 usa "worker worker-base" para NÃO recriar a stack
# de controlo (directus/nats/redis/minio/dashboard) numa mudança de .env dos workers.
# COMPOSE_SERVICES=worker worker-base
