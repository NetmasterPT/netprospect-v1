# deploy/npmplus/.env — segredos do stack NPMplus (reverse-proxy, CT hel1-npm / VMID 103).
# NUNCA committar (gitignored). Na box vive em /opt/.env; o compose.yaml lê-os via ${VAR}
# (docker compose --project-directory /opt --env-file /opt/.env ...). Ver README.md.
#
# Bootstrap (uma vez, na box):  cp .env.example /opt/.env  &&  preencher os valores reais.
# Os valores atuais estão no backup pré-migração (npmplus-predeploy-migration-*.tar.gz → ./compose.yaml)
# e no vzdump PBS ct/103 "antes de migrar NPMplus deploy".

# NPMplus ↔ Authentik OIDC (Authentik → Applications → Providers → npmplus)
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# CrowdSec LAPI key (cscli bouncers add npmplus  /  gerado no 1º arranque)
CROWDSEC_LAPI_KEY=

# Tailscale auth key do CT (https://login.tailscale.com/admin/settings/keys) — reusable/ephemeral
TS_AUTHKEY=

# Authentik — password do Postgres (MESMO valor nos 3 serviços) + secret key (openssl rand -hex 32)
AUTHENTIK_PG_PASSWORD=
AUTHENTIK_SECRET_KEY=

# openappsec (WAF) — password do Postgres interno (openappsec-db + openappsec-tuning-svc)
OPENAPPSEC_DB_PASSWORD=
