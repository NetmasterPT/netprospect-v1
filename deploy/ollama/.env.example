# IP tailnet DESTA VM (tailscale ip -4). O Ollama não tem auth → NUNCA 0.0.0.0.
TAILNET_IP=

# Modelo (o mesmo do HEL1 para os prompts não mudarem de comportamento)
OLLAMA_MODEL=gemma3:4b

# Em CPU o load a frio é caro → manter residente. 1 inferência de cada vez (paralelizar = thrashing).
OLLAMA_KEEP_ALIVE=24h
OLLAMA_NUM_PARALLEL=1
